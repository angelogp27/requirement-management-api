					"name": "1.1 Crear Usuario - Jefe de Proyecto",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.collectionVariables.set('jefeId', jsonData.data.id);",
									"    pm.collectionVariables.set('usuarioId', jsonData.data.id);",
									"}",
									"pm.test('Status 201', function() {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test('Usuario creado con rol JEFE_PROYECTO', function() {",
									"    pm.expect(jsonData.data.rol).to.eql('JEFE_PROYECTO');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"jperez\",\n    \"password\": \"123456\",\n    \"email\": \"jperez@universidad.edu.pe\",\n    \"rol\": \"JEFE_PROYECTO\"\n}"
